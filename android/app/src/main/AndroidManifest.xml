<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- Required for screen-share on Android 14+ : MediaProjection
         demands a foreground service of TYPE_MEDIA_PROJECTION before
         the user-grant intent can be consumed. Without these the
         flutter_webrtc plugin's getDisplayMedia call throws
         SecurityException and the app crashes. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <!-- Permissions for keeping the mic + camera alive while a P2P call
         is in progress AND the screen is off / app is in the background.
         On Android 14+ the OS revokes runtime mic/camera access from any
         non-foreground process after a few seconds. Holding a foreground
         service of the appropriate type tells the OS "this app is doing
         a phone call right now, do NOT revoke" — same mechanism every
         system dialer uses.

         IMPORTANT: declaring the permission alone is NOT enough. To
         actually use it, a Kotlin foreground service class with the
         matching `android:foregroundServiceType` must be running for
         the duration of the call. See `MediaProjectionFgService.kt`
         for the existing pattern used by screen sharing; an analogous
         `OngoingCallFgService.kt` should be added and started from
         the Flutter side via a method channel the moment a call
         enters the `connecting` phase, and stopped on `ended`. Without
         that service running, these permissions are inert — the
         declarations below are wired so the eventual service class
         can claim them without another manifest change. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />
    <!-- Android 13+ requires a runtime grant for showing notifications.
         FCM uses this for chat / call / meeting push messages. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Wake the device for incoming-call notifications so the
         ringtone fires even when the screen is off. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Read-back of meetings the user saved in Google Calendar via
         the in-app "Schedule Meeting" flow. We only READ — write is
         done by Calendar itself when the user taps Save. Without
         this we can never know the actual saved start/end times and
         Upcoming Meetings would have to display a guess. -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />
    <!-- Read the device address book so we can show "Mizdah contacts"
         in the Call tab (WhatsApp-style). We never upload contact
         names — only phone numbers and emails are sent to the
         backend's /api/users/contacts/match endpoint, and even those
         are forgotten by the server the moment the match response
         comes back. See docs/PHONE_AND_CONTACTS_BACKEND.md §11 and
         lib/core/services/contacts_service.dart. -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-feature android:name="android.hardware.camera" />
    <uses-feature android:name="android.hardware.camera.autofocus" />
    
    <application
        android:label="mizdah"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize"
            android:supportsPictureInPicture="true"
            android:resizeableActivity="true">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- ── FCM display defaults ──────────────────────────────
             These three meta-data entries are what Android uses when
             the FCM payload doesn't specify them per-message. The
             `default_notification_channel_id` is REQUIRED on Android
             8+ — without it, a notification whose payload omits a
             channel id gets silently dropped (the OS won't fall back
             to a magic "Miscellaneous" channel any more). The matching
             channel is created from Kotlin in MainActivity.onCreate so
             it exists before the first push lands. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@mipmap/ic_launcher" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/notification_color" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="mizdah_general_v1" />

        <!-- Foreground service for screen capture on Android 14+.
             Starting Android 14, MediaProjection requires a running
             foreground service of TYPE_MEDIA_PROJECTION before the
             OS will hand over the projection token.
             The service class is implemented in Kotlin under
             android/app/src/main/kotlin/.../MediaProjectionFgService.kt
             — Flutter starts/stops it via a method channel before
             calling getDisplayMedia. -->
        <service
            android:name=".MediaProjectionFgService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!-- Foreground service for ongoing P2P video / voice calls.
             Keeps mic + camera alive when the screen is locked or the
             app is backgrounded. Without this, Android 14+ revokes
             runtime mic/camera access from any non-foreground process
             after a few seconds — which is exactly why audio dropped
             2–3s after the power button was pressed.

             Service type combines `microphone | camera | phoneCall`
             so the OS treats this as a real phone call and applies
             dialer-style affordances (do-not-disturb bypass, etc.).

             Started/stopped from Dart via the com.mizdah/call_fg
             method channel — see P2PCallNotifier in
             lib/features/call/p2p_call_provider.dart. -->
        <service
            android:name=".OngoingCallFgService"
            android:exported="false"
            android:foregroundServiceType="microphone|camera|phoneCall" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
