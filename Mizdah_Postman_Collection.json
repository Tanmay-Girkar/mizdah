                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"mypassword\"\n}"
            }
          }
        },
        {
          "name": "Get Current User",
          "event": [],
